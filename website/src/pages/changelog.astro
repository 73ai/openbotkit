---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import fs from 'node:fs';
import path from 'node:path';

interface ChangeItem {
  title: string;
  description: string;
}

interface Category {
  name: string;
  items: ChangeItem[];
}

interface Release {
  date: string;
  categories: Category[];
}

function parseChangelog(md: string): Release[] {
  const releases: Release[] = [];
  let current: Release | null = null;
  let currentCat: Category | null = null;

  for (const line of md.split('\n')) {
    const dateMatch = line.match(/^## (\d{4}-\d{2}-\d{2})/);
    if (dateMatch) {
      current = { date: dateMatch[1], categories: [] };
      releases.push(current);
      currentCat = null;
      continue;
    }

    const catMatch = line.match(/^### (.+)/);
    if (catMatch && current) {
      currentCat = { name: catMatch[1], items: [] };
      current.categories.push(currentCat);
      continue;
    }

    const itemMatch = line.match(/^- \*\*(.+?)\*\*:\s*(.+)/);
    if (itemMatch && currentCat) {
      currentCat.items.push({ title: itemMatch[1], description: itemMatch[2] });
    }
  }

  return releases;
}

function inlineMarkdown(text: string): string {
  const codeClass = 'rounded bg-heading/10 px-1.5 py-0.5 text-[1rem] text-heading';
  return text.replace(/`([^`]+)`/g, `<code class="${codeClass}">$1</code>`);
}

const raw = fs.readFileSync(path.resolve(process.cwd(), '..', 'CHANGELOG.md'), 'utf-8');
const releases = parseChangelog(raw);
---

<Layout
  title="Changelog - OpenBotKit"
  description="What's new in OpenBotKit: recent features, improvements, and fixes."
>
  <Nav />
  <main class="mx-auto max-w-2xl px-6 pt-32 pb-20">
    <h1 class="text-[2.4rem] font-bold leading-[1.3] text-heading">Changelog</h1>
    <p class="mt-4 text-[1.25rem] leading-[1.7] text-paragraph">
      Major user-facing changes, hand-curated from the commit history.
    </p>

    {releases.map((release, i) => (
      <section class={i === 0 ? 'mt-16' : 'mt-16 border-t border-border pt-12'}>
        <h2 class="text-[1.4rem] font-semibold leading-[1.7] text-heading">{release.date}</h2>

        {release.categories.map((cat) => (
          <>
            <h3 class="mt-6 text-[1.2rem] font-semibold leading-[1.7] text-heading">{cat.name}</h3>
            <ul class="mt-2 list-disc pl-6 text-[1.25rem] leading-[1.7] text-paragraph">
              {cat.items.map((item) => (
                <li>
                  <span class="font-bold text-heading">{item.title}</span>:
                  <Fragment set:html={inlineMarkdown(item.description)} />
                </li>
              ))}
            </ul>
          </>
        ))}
      </section>
    ))}
  </main>
  <Footer />
</Layout>
