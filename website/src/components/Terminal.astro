---
---

<div class="terminal-wrapper overflow-hidden rounded-xl border border-[#3a3a3a] bg-[#2a2a2a]">
  <div class="flex items-center justify-between px-4 py-3 border-b border-[#3a3a3a]">
    <div class="flex items-center gap-2">
      <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
    </div>
    <button
      class="copy-btn text-[#666] hover:text-[#ccc] transition-colors cursor-pointer"
      aria-label="Copy commands"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
    </button>
  </div>
  <div class="terminal-content overflow-x-auto px-6 py-5 font-mono text-[0.85rem] leading-[2.2] text-[#ccc] whitespace-nowrap">
    <slot />
  </div>
</div>

<script>
  document.querySelectorAll('.terminal-wrapper').forEach((wrapper) => {
    const btn = wrapper.querySelector('.copy-btn');
    const content = wrapper.querySelector('.terminal-content');
    if (!btn || !content) return;
    btn.addEventListener('click', () => {
      const lines = content.querySelectorAll('div');
      const text = Array.from(lines)
        .map((line) => line.textContent?.replace(/^\$\s*/, '').trim())
        .filter(Boolean)
        .join('\n');
      navigator.clipboard.writeText(text).then(() => {
        btn.innerHTML = `<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
        setTimeout(() => {
          btn.innerHTML = `<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;
        }, 2000);
      });
    });
  });
</script>
